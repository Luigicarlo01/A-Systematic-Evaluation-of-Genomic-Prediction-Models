# RKHS Helper: Cálculo do Kernel Gaussiano (RBF)
# (Inalterada)
# -------------------------
def calculate_rbf_kernel(X_train, X_val, gamma=None):
    if gamma is None:
        gamma = 1.0 / X_train.shape[1]

    dist_sq_train = pairwise_distances(X_train, metric='sqeuclidean')
    K_train = np.exp(-gamma * dist_sq_train)

    dist_sq_val = pairwise_distances(X_val, X_train, metric='sqeuclidean')
    K_val = np.exp(-gamma * dist_sq_val)

    return K_train, K_val

