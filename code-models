# FUNCTIONS: build Keras models (Compilando com loss='mse' para Y normalizado)
# (As funções build_dnn, build_dnn_l1, etc., permanecem inalteradas, pois usam loss='mse')
# -------------------------
def get_adamw(lr=1e-3, wd=1e-5):
    return keras.optimizers.Adam(learning_rate=lr)

def build_dnn(input_dim):
    model = keras.Sequential([
        layers.Input(shape=(input_dim,)),
        layers.Dense(512, activation='relu'), layers.Dropout(0.3),
        layers.Dense(256, activation='relu'), layers.Dropout(0.3),
        layers.Dense(64, activation='relu'),
        layers.Dense(1, activation='linear')
    ])
    model.compile(optimizer=get_adamw(1e-3), loss='mse')
    return model
def build_dnn_l1(input_dim, l1_reg=1e-5):
    model = keras.Sequential([
        layers.Input(shape=(input_dim,)),
        layers.Dense(512, activation='relu', kernel_regularizer=keras.regularizers.l1(l1_reg)),
        layers.Dropout(0.3),
        layers.Dense(256, activation='relu', kernel_regularizer=keras.regularizers.l1(l1_reg)),
        layers.Dropout(0.3),
        layers.Dense(64, activation='relu', kernel_regularizer=keras.regularizers.l1(l1_reg)),
        layers.Dense(1, activation='linear')
    ])
    model.compile(optimizer=get_adamw(1e-3), loss='mse')
    return model
def build_dnn_l1l2(input_dim, l_reg=1e-5):
    model = keras.Sequential([
        layers.Input(shape=(input_dim,)),
        layers.Dense(512, activation='relu', kernel_regularizer=keras.regularizers.l1_l2(l_reg, l_reg)),
        layers.Dropout(0.3),
        layers.Dense(256, activation='relu', kernel_regularizer=keras.regularizers.l1_l2(l_reg, l_reg)),
        layers.Dropout(0.3),
        layers.Dense(64, activation='relu', kernel_regularizer=keras.regularizers.l1_l2(l_reg, l_reg)),
        layers.Dense(1, activation='linear')
    ])
    model.compile(optimizer=get_adamw(1e-3), loss='mse')
    return model
def build_mlp_l1l2(input_dim):
    # Reduzindo a regularização e o dropout para maior estabilidade
    model = keras.Sequential([
        layers.Input(shape=(input_dim,)),
        layers.Dense(256, activation='relu', kernel_regularizer=keras.regularizers.l1_l2(1e-6,1e-6)), # Regularização reduzida
        layers.Dropout(0.1), # Dropout reduzido
        layers.Dense(128, activation='relu', kernel_regularizer=keras.regularizers.l1_l2(1e-6,1e-6)), # Regularização reduzida
        layers.Dropout(0.1), # Dropout reduzido
        layers.Dense(1)
    ])
    model.compile(optimizer=get_adamw(5e-4), loss='mse')
    return model
def build_cnn(input_shape):
    tf.keras.utils.set_random_seed(RANDOM_SEED)
    # Ajustando a arquitetura para maior estabilidade e capacidade
    model = keras.Sequential([
        layers.Input(shape=input_shape),
        layers.Conv1D(filters=64, kernel_size=5, activation='relu', padding='same'), # Filtros aumentados, kernel menor
        layers.MaxPooling1D(pool_size=2),
        layers.Dropout(0.1), # Dropout reduzido
        layers.Conv1D(filters=32, kernel_size=3, activation='relu', padding='same'),
        layers.MaxPooling1D(pool_size=2),
        layers.Flatten(),
        layers.Dense(64, activation='relu', kernel_regularizer=keras.regularizers.l2(0.001)), # Adicionando regularização L2
        layers.Dropout(0.2),
        layers.Dense(1, activation='linear')
    ])
    model.compile(optimizer=keras.optimizers.Adam(0.001), loss='mse')
    return model
def build_cnn_l1(input_shape, l1_reg=1e-5):
    tf.keras.utils.set_random_seed(RANDOM_SEED)
    model = keras.Sequential([
        layers.Input(shape=input_shape),
        layers.Conv1D(filters=32, kernel_size=12, activation='relu', padding='same', kernel_regularizer=keras.regularizers.l1(l1_reg)),
        layers.MaxPooling1D(pool_size=2),
        layers.Dropout(0.2),
        layers.Conv1D(filters=64, kernel_size=12, activation='relu', padding='same', kernel_regularizer=keras.regularizers.l1(l1_reg)),
        layers.MaxPooling1D(pool_size=2),
        layers.Flatten(),
        layers.Dense(50, activation='relu', kernel_regularizer=keras.regularizers.l1(l1_reg)),
        layers.Dropout(0.3),
        layers.Dense(1, activation='linear')
    ])
    model.compile(optimizer=keras.optimizers.Adam(0.001), loss='mse')
    return model
def build_cnn_l1l2(input_shape, l_reg=1e-5):
    tf.keras.utils.set_random_seed(RANDOM_SEED)
    model = keras.Sequential([
        layers.Input(shape=input_shape),
        layers.Conv1D(filters=32, kernel_size=12, activation='relu', padding='same', kernel_regularizer=keras.regularizers.l1_l2(l_reg, l_reg)),
        layers.MaxPooling1D(pool_size=2),
        layers.Dropout(0.2),
        layers.Conv1D(filters=64, kernel_size=12, activation='relu', padding='same', kernel_regularizer=keras.regularizers.l1_l2(l_reg, l_reg)),
        layers.MaxPooling1D(pool_size=2),
        layers.Flatten(),
        layers.Dense(50, activation='relu', kernel_regularizer=keras.regularizers.l1_l2(l_reg, l_reg)),
        layers.Dropout(0.3),
        layers.Dense(1, activation='linear')
    ])
    model.compile(optimizer=keras.optimizers.Adam(0.001), loss='mse')
    return model
def build_attentionnet(input_dim):
    inp = layers.Input(shape=(input_dim,))
    x = layers.Dense(512, activation='relu')(inp)
    L = 16
    if x.shape[-1] != L * 32:
        x = layers.Dense(L * 32, activation='relu')(x)
    proj = layers.Reshape((L, 32))(x)
    att = layers.MultiHeadAttention(num_heads=4, key_dim=8)(proj, proj)
    pooled = layers.GlobalAveragePooling1D()(att)
    x = layers.Concatenate()([layers.Flatten()(x), pooled])
    x = layers.Dense(128, activation='relu')(x)
    out = layers.Dense(1)(x)
    model = keras.Model(inp,out)
    model.compile(optimizer=get_adamw(1e-3), loss='mse')
    return model
def build_epistatic_net_simplified(input_dim, l1_reg=1e-5, l2_reg=1e-4):
    regularizer = keras.regularizers.l1_l2(l1=l1_reg, l2=l2_reg)
    model = keras.Sequential([
        layers.Input(shape=(input_dim,)),
        layers.Dense(512, activation='relu', kernel_regularizer=regularizer),
        layers.Dropout(0.3),
        layers.Dense(256, activation='relu', kernel_regularizer=regularizer),
        layers.Dropout(0.3),
        layers.Dense(64, activation='relu'),
        layers.Dense(1, activation='linear')
    ])
    model.compile(optimizer=get_adamw(1e-3), loss='mse')
    return model
def build_deepgs(input_shape):
    model = keras.Sequential([
        layers.Input(shape=input_shape),
        layers.Conv1D(8, kernel_size=5, activation='relu', padding='same'),
        layers.BatchNormalization(),
        layers.MaxPooling1D(pool_size=2),
        layers.Flatten(),
        layers.Dense(32, activation='relu'),
        layers.BatchNormalization(),
        layers.Dense(1)
    ])
    model.compile(optimizer=get_adamw(1e-3), loss='mse')
    return model
def build_dgsn(input_dim):
    model = keras.Sequential([
        layers.Input(shape=(input_dim,)),
        layers.Dense(512, activation='relu', kernel_regularizer=keras.regularizers.l1_l2(l1=1e-5, l2=1e-4)),
        layers.Dropout(0.3),
        layers.Dense(256, activation='relu', kernel_regularizer=keras.regularizers.l1_l2(l1=1e-5, l2=1e-4)),
        layers.Dropout(0.3),
        layers.Dense(64, activation='relu'),
        layers.Dense(1, activation='linear')
    ])
    model.compile(optimizer=get_adamw(1e-3), loss='mse')
    return model

