def run_rkhs_model(name, K_train, K_val, Y_train_norm, Y_val_norm, Y_val_orig, Y_scaler):
    print(f"\n--- {name} ---")
    start_time = time.time()
    try:
        model = KernelRidge(alpha=1.0, kernel='precomputed')
        model.fit(K_train, Y_train_norm)
        y_pred_norm = model.predict(K_val)
        evaluate_and_store(name, y_pred_norm, Y_val_norm, start_time, Y_val_orig, Y_scaler)
    except Exception as e:
        print(f"❌ Erro ao treinar/avaliar {name}: {e}")
        error_metrics = {k: np.nan for k in ['Acurácia', 'Acurácia_std', 'Viés (b)', 'Viés (b)_std', 'RMSE', 'RMSE_std', 'RMSE (10% Melhores)', 'RMSE (10% Melhores)_std', 'Top10 Predito (média real)', 'Top10 Predito (média real)_std', 'Hit Rate (10% Coinc.)', 'Hit Rate (10% Coinc.)_std', 'NDCG', 'NDCG_std']}
        results[name] = {**error_metrics, 'Tempo (s)': time.time() - start_time, 'y_pred': np.full_like(Y_val_orig, np.nan)}

# -------------------------
# Cálculo das matrizes genômicas G, D e I
# (Inalterada)
# -------------------------
def calculate_genomic_matrices(X_scaled, X_raw):
    n_individuals, n_markers = X_scaled.shape
    den_sum = np.sum(np.power(X_scaled.std(axis=0),2)) * n_individuals
    den_sum = den_sum if den_sum != 0 else 1e-6
    G = np.dot(X_scaled, X_scaled.T) / den_sum
    p = X_raw.mean(axis=0)/2.0
    q = 1-p
    den_dom_val = 2*p*q
    den_dom_val[den_dom_val==0] = 1e-6
    W = np.zeros_like(X_raw)
    W[X_raw==1] = 1
    W_scaled = (W - den_dom_val)/np.sqrt(den_dom_val)
    den_sum_dom = np.sum(den_dom_val)
    den_sum_dom = den_sum_dom if den_sum_dom != 0 else 1e-6
    D = np.dot(W_scaled, W_scaled.T)/den_sum_dom
    I = G*G
    return G, D, I, den_sum, den_dom_val, W_scaled

# -------------------------
# Cálculo das matrizes genômicas validação (Cross-Kernel)
# (Inalterada)
# -------------------------
def calculate_validation_kernels(X_val_scaled, X_val_raw, X_train_scaled, den_sum, den_dom_val, W_train_scaled):
    G_val = np.dot(X_val_scaled, X_train_scaled.T) / den_sum
    W_val_raw = np.zeros_like(X_val_raw)
    W_val_raw[X_val_raw==1] = 1
    W_val_scaled = (W_val_raw - den_dom_val)/np.sqrt(den_dom_val)
    D_val = np.dot(W_val_scaled, W_train_scaled.T)/np.sum(den_dom_val)
    I_val = G_val*G_val
    return G_val, D_val, I_val

