def plot_training_history(history, model_name, plots_dir):
    plt.figure(figsize=(12, 5))

    # Plot Loss
    plt.subplot(1, 2, 1)
    plt.plot(history.history['loss'], label='Treino Loss')
    if 'val_loss' in history.history:
        plt.plot(history.history['val_loss'], label='Validação Loss')
    plt.title(f'Loss do Modelo: {model_name}')
    plt.ylabel('Loss (MSE)')
    plt.xlabel('Época')
    plt.legend(loc='upper right')
    plt.grid(True)

    # Plot Metric (RMSE)
    plt.subplot(1, 2, 2)
    # A métrica é 'root_mean_squared_error' se for usada no compile
    metric_key = 'root_mean_squared_error' if 'root_mean_squared_error' in history.history else 'loss' # Fallback
    val_metric_key = 'val_root_mean_squared_error' if 'val_root_mean_squared_error' in history.history else 'val_loss' # Fallback

    plt.plot(history.history[metric_key], label=f'Treino {metric_key}')
    if val_metric_key in history.history:
        plt.plot(history.history[val_metric_key], label=f'Validação {metric_key}')
    plt.title(f'Métrica do Modelo: {model_name}')
    plt.ylabel('RMSE (Normalizado)')
    plt.xlabel('Época')
    plt.legend(loc='upper right')
    plt.grid(True)

    plt.tight_layout()
    plt.savefig(os.path.join(plots_dir, f'{model_name}_training_history.png'))
    plt.close()
    print(f"Gráfico de histórico de treino salvo para {model_name}.")

# -------------------------
# Helper: NDCG
# -------------------------
def ndcg_score(y_true, y_pred, k=None):
    """Calcula o NDCG para uma lista de predições e valores verdadeiros."""
    y_true = np.asarray(y_true).flatten()
    y_pred = np.asarray(y_pred).flatten()

    if k is None:
        k = len(y_true)

    desc_rank_idx = np.argsort(y_pred)[::-1][:k]
    ranked_true = y_true[desc_rank_idx]

    discounts = np.log2(np.arange(2, len(ranked_true) + 2))
    dcg = np.sum(ranked_true / discounts)

    ideal_ranked_true = np.sort(y_true)[::-1][:k]
    idcg = np.sum(ideal_ranked_true / discounts)

    return dcg / idcg if idcg > 0 else 0.0

# -------------------------
# Helper: evaluation (AGORA CALCULA SRMSE E OUTRAS MÉTRICAS NA ESCALA ORIGINAL)
# -------------------------
def evaluate_and_store(name, y_pred_norm, y_true_norm, start_time, y_true_original, y_scaler):
    duration = time.time() - start_time

    # Desnormalização para métricas de seleção/interpretabilidade prática (Acc, HitRate, NDCG)
    y_pred_orig = y_scaler.inverse_transform(y_pred_norm.reshape(-1, 1)).flatten()
    y_true_orig = y_true_original

    n_samples = len(y_true_orig)

    # Checagem de NaNs
    if np.isnan(y_pred_orig).any() or np.isnan(y_true_orig).any() or n_samples == 0:
        print(f"❌ {name} — Contém NaNs ou dados vazios, pulando bootstrap.")
        error_metrics = {k: np.nan for k in ['Acurácia', 'Acurácia_std', 'Viés (b)', 'Viés (b)_std', 'RMSE', 'RMSE_std', 'RMSE (10% Melhores)', 'RMSE (10% Melhores)_std', 'Top10 Predito (média real)', 'Top10 Predito (média real)_std', 'Hit Rate (10% Coinc.)', 'Hit Rate (10% Coinc.)_std', 'NDCG', 'NDCG_std', 'Viés^2 (Boot)', 'Variância (Boot)']}
        results[name] = {**error_metrics, 'Tempo (s)': float(duration), 'y_pred': y_pred_orig}
        return

    # Listas para armazenar resultados do bootstrap
    boot_accs = []; boot_rmses = []; boot_biases = []
    boot_rmse_top10s = []; boot_mean_tops = []; boot_hit_rates = []; boot_ndcgs = []
    all_boot_predictions_norm = []

    # Loop de Bootstrap
    for _ in range(N_BOOTSTRAPS):
        try:
            # Reamostra com reposição
            boot_idx = np.random.choice(n_samples, size=n_samples, replace=True)

            # Amostras ORIGINAIS (para Acc, Viés, HitRate, Top10, NDCG)
            y_true_orig_boot = y_true_orig[boot_idx]
            y_pred_orig_boot = y_pred_orig[boot_idx]

            # Amostras NORMALIZADAS (PARA SRMSE)
            y_true_norm_boot = y_true_norm[boot_idx]
            y_pred_norm_boot = y_pred_norm[boot_idx]

            # 1. Pearson (accuracy) - Usa dados ORIGINAIS
            if np.std(y_pred_orig_boot) > 1e-6 and np.std(y_true_orig_boot) > 1e-6:
                acc = pearsonr(y_pred_orig_boot, y_true_orig_boot)[0]
                boot_accs.append(acc)

            # RMSE (SRMSE) - Usa dados NORMALIZADOS
            rmse = np.sqrt(mean_squared_error(y_true_norm_boot, y_pred_norm_boot))
            boot_rmses.append(rmse)

            # Calibração: Viés (b) - Usa dados ORIGINAIS
            if np.std(y_pred_orig_boot) > 1e-6:
                bias_b = LinearRegression().fit(y_pred_orig_boot.reshape(-1,1), y_true_orig_boot.reshape(-1,1)).coef_[0][0]
                boot_biases.append(bias_b)

            # 2. RMSE top 10% reais (SRMSE top 10%) - Usa dados NORMALIZADOS, mas o índice é baseado no ranking ORIGINAL
            limiar_true_orig_boot = np.percentile(y_true_orig_boot, 90)
            idx_top_real_orig_boot = np.where(y_true_orig_boot >= limiar_true_orig_boot)[0]

            if len(idx_top_real_orig_boot) > 1:
                rmse_top10 = np.sqrt(mean_squared_error(y_true_norm_boot[idx_top_real_orig_boot], y_pred_norm_boot[idx_top_real_orig_boot]))
                boot_rmse_top10s.append(rmse_top10)

            # 3. Média verdadeira dos top10 preditos - Usa dados ORIGINAIS
            lim_pred_orig_boot = np.percentile(y_pred_orig_boot, 90)
            idx_top_pred_orig_boot = np.where(y_pred_orig_boot >= lim_pred_orig_boot)[0]
            if len(idx_top_pred_orig_boot) > 0:
                mean_top_pred_real = y_true_orig_boot[idx_top_pred_orig_boot].mean()
                boot_mean_tops.append(mean_top_pred_real)

            # 4. Taxa de Coincidência (Hit Rate) - Usa índices ORIGINAIS
            num_selected_boot = len(idx_top_pred_orig_boot)
            num_top_real_boot = len(idx_top_real_orig_boot)
            if num_selected_boot > 0 and num_top_real_boot > 0:
                overlap = len(np.intersect1d(idx_top_pred_orig_boot, idx_top_real_orig_boot))
                hit_rate = overlap / num_selected_boot
                boot_hit_rates.append(hit_rate)
            else:
                boot_hit_rates.append(0.0)

            # 5. NDCG - Usa dados ORIGINAIS
            ndcg = ndcg_score(y_true_orig_boot, y_pred_orig_boot, k=int(n_samples*0.1))
            boot_ndcgs.append(ndcg)

            # Coletar predições de validação (NORMALIZADAS) para Viés/Variância
            all_boot_predictions_norm.append(y_pred_norm_boot)

        except Exception as e:
            continue

    # Calcula Média e Desvio Padrão
    acc_mean, acc_std = (np.mean(boot_accs), np.std(boot_accs)) if boot_accs else (np.nan, np.nan)
    rmse_mean, rmse_std = (np.mean(boot_rmses), np.std(boot_rmses)) if boot_rmses else (np.nan, np.nan)
    bias_mean, bias_std = (np.mean(boot_biases), np.std(boot_biases)) if boot_biases else (np.nan, np.nan)
    rmse10_mean, rmse10_std = (np.mean(boot_rmse_top10s), np.std(boot_rmse_top10s)) if boot_rmse_top10s else (np.nan, np.nan)
    top10_mean, top10_std = (np.mean(boot_mean_tops), np.std(boot_mean_tops)) if boot_mean_tops else (np.nan, np.nan)
    hr_mean, hr_std = (np.mean(boot_hit_rates), np.std(boot_hit_rates)) if boot_hit_rates else (np.nan, np.nan)
    ndcg_mean, ndcg_std = (np.mean(boot_ndcgs), np.std(boot_ndcgs)) if boot_ndcgs else (np.nan, np.nan)

    # 6. Estimação de Viés/Variância (usando as predições de bootstrap NORMALIZADAS)
    if all_boot_predictions_norm:
        # PRED: Média das predições de todas as iterações de bootstrap (Estimativa de E[f_hat(x)])
        mean_preds = np.mean(all_boot_predictions_norm, axis=0)

        # VARIÂNCIA: Média da variância das predições em cada ponto (Estimativa de E[(f_hat - E[f_hat])^2]) - Usando dados NORMALIZADOS
        variance_boot = np.mean(np.var(all_boot_predictions_norm, axis=0))

        # VIÉS^2: Média do viés quadrado em cada ponto (Estimativa de (E[f_hat] - f(x))^2) - Usando dados NORMALIZADOS
        # Usamos o Y_true_norm (valor real NORMALIZADO) como f(x)
        bias_squared_boot = np.mean((mean_preds - y_true_norm)**2)
    else:
        variance_boot = np.nan
        bias_squared_boot = np.nan

    # Armazena os resultados (agora RMSE é SRMSE)
    results[name] = {
        'Acurácia': float(acc_mean), 'Acurácia_std': float(acc_std),
        'Viés (b)': float(bias_mean), 'Viés (b)_std': float(bias_std),
        'RMSE': float(rmse_mean), 'RMSE_std': float(rmse_std),
        'RMSE (10% Melhores)': float(rmse10_mean), 'RMSE (10% Melhores)_std': float(rmse10_std),
        'Top10 Predito (média real)': float(top10_mean), 'Top10 Predito (média real)_std': float(top10_std),
        'Hit Rate (10% Coinc.)': float(hr_mean), 'Hit Rate (10% Coinc.)_std': float(hr_std),
        'NDCG': float(ndcg_mean), 'NDCG_std': float(ndcg_std),
        'Viés^2 (Boot)': float(bias_squared_boot), # NOVO
        'Variância (Boot)': float(variance_boot), # NOVO
        'Tempo (s)': float(duration),
        'y_pred': y_pred_orig # Armazena o desnormalizado para plots de dispersão
    }

    # Linha de impressão corrigida, incluindo Viés^2 e Variância
    print(f"✅ {name} — Acc={acc_mean:.4f} (±{acc_std:.4f}), SRMSE(Norm)={rmse_mean:.4f} (±{rmse_std:.4f}), Viés²={bias_squared_boot:.4f}, Var={variance_boot:.4f}, Tempo={duration:.2f}s")

